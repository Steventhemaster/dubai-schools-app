# ── Supabase (target) ──────────────────────────────────────────────────────
# Use the SERVICE ROLE key here (server-side only — never ship to the app).
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ── KHDA official workbook (RECOMMENDED source — no key/login needed) ───────
# Download once from:
#   https://web.khda.gov.ae/KHDA/media/KHDA/DubaiPrivateSchoolsOpenData.xlsx
# Then: npm run ingest -- --source=khda
KHDA_XLSX_PATH=./downloads/DubaiPrivateSchoolsOpenData.xlsx

# ── Dubai Pulse / KHDA open data API ───────────────────────────────────────
# Request free access at https://www.dubaipulse.gov.ae → you receive an
# API Key + API Secret by email. The pipeline exchanges them for an OAuth token.
DUBAI_PULSE_API_KEY=
DUBAI_PULSE_API_SECRET=

# Dataset resource id to pull (confirm the exact id on the dataset page).
# Run `npm run describe` first to print the columns of whatever you point at.
DUBAI_PULSE_RESOURCE_ID=khda_dubai_private_schools

# ── CSV source (fallback / manual download) ────────────────────────────────
CSV_PATH=./sample/khda_sample.csv
